{
  "name": "vidernu",
  "version": "0.1.0",
  "description": "Privacy-first, local-inference language-learning Chrome extension for YouTube captions.",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "vite build"
  },
  "dependencies": {
    "@huggingface/transformers": "3.8.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.7.1",
    "@eslint/js": "10.0.1",
    "@types/chrome": "0.2.2",
    "@types/node": "26.1.0",
    "eslint": "10.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  }
}
